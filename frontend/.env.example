# Backend base URL the dev server proxies /api/* to.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Show the "Continue with Microsoft" SSO button on the login page.
NEXT_PUBLIC_MICROSOFT_SSO=false

# Comma-separated org email domains — recipients outside these are flagged external.
NEXT_PUBLIC_ORG_DOMAINS=sapphirebroking.com
