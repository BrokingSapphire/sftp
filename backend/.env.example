# ─────────────────────────────────────────────────────────────
# SFTP Platform — secrets & connection strings.
# Copy to .env (prod) or .env.local (dev). NEVER commit real values.
# Env vars override config.yaml. Naming: <SECTION>_<FIELD>, uppercase.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (section "database", field "url").
DATABASE_URL=postgresql://sftp:sftp@localhost:5432/sftp?sslmode=disable

# JWT signing secret (section "jwt", field "secret"). Min 32 chars.
# Generate: openssl rand -base64 48
JWT_SECRET=change-this-to-a-random-secret-at-least-32-characters-long

# First-run super-admin (created only when the DB has no users).
BOOTSTRAP_ADMIN_PASSWORD=change-me-a-strong-admin-password
# BOOTSTRAP_ADMIN_EMAIL=admin@sapphirebroking.com
# BOOTSTRAP_ADMIN_USERNAME=admin

# Microsoft Entra ID (Azure AD) SSO — only if sso.microsoft.enabled=true
# SSO_MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000
# SSO_MICROSOFT_CLIENT_SECRET=your-client-secret

# Encrypt file content at rest (AES-256). 64 hex chars (32 bytes).
# Generate: openssl rand -hex 32   — LOSING THIS KEY MAKES FILES UNREADABLE.
# STORAGE_ENCRYPTION_KEY=

# Optional overrides:
# APP_ENVIRONMENT=production
# APP_PORT=8080
# LOGGING_LEVEL=info
# STORAGE_ROOT_PATH=/srv/sftp/files
# STORAGE_MAX_UPLOAD_SIZE=0
# REDIS_ENABLED=false
# REDIS_ADDRESS=localhost:6379

# SMTP (on-prem) for share emails — only if mail.enabled=true
# MAIL_HOST=smtp.corp.local
# MAIL_USERNAME=
# MAIL_PASSWORD=
# ORG_DOMAINS=sapphirebroking.com
