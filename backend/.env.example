# ─────────────────────────────────────────────────────────────
# SFTP Platform — secrets & connection strings.
# Copy to .env (prod) or .env.local (dev). NEVER commit real values.
# Env vars override config.yaml. Naming: <SECTION>_<FIELD>, uppercase.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (section "database", field "url").
DATABASE_URL=postgresql://sftp:sftp@localhost:5432/sftp?sslmode=disable

# JWT signing secret (section "jwt", field "secret"). Min 32 chars.
# Generate: openssl rand -base64 48
JWT_SECRET=change-this-to-a-random-secret-at-least-32-characters-long

# Optional overrides:
# APP_ENVIRONMENT=production
# APP_PORT=8080
# LOGGING_LEVEL=info
# STORAGE_ROOT_PATH=/srv/sftp/files
# STORAGE_MAX_UPLOAD_SIZE=0
# REDIS_ENABLED=false
# REDIS_ADDRESS=localhost:6379
