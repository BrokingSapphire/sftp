# ─────────────────────────────────────────────────────────────
# Full-stack deployment (docker-compose.yml at repo root).
# Copy to `.env`, fill in secrets, then: docker compose up -d --build
# ─────────────────────────────────────────────────────────────

# Public URL users hit (used for CORS + share links). No trailing slash.
PUBLIC_URL=http://localhost

# PostgreSQL
POSTGRES_USER=sftp
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=sftp

# JWT signing secret — REQUIRED, min 32 chars.  openssl rand -base64 48
JWT_SECRET=

# First-run super-admin (created only when the database has no users).
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-admin-password
