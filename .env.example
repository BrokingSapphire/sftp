# ─────────────────────────────────────────────────────────────
# SFTP Platform — Environment Configuration
# Copy to `.env` and adjust. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# ── Application ──
APP_ENV=development                 # development | production
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=0s             # 0 = unlimited (large streaming downloads)
SERVER_SHUTDOWN_TIMEOUT=30s
ALLOWED_ORIGINS=http://localhost:3000

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sftp
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=sftp
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=50
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME=1h

# ── JWT / Auth ──
# Generate: openssl rand -base64 48
JWT_SECRET=please-change-this-to-a-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h                # 7 days
JWT_ISSUER=sftp

# ── Storage ──
UPLOAD_PATH=./storage/files
TEMP_PATH=./storage/tmp
MAX_UPLOAD_SIZE=0                   # bytes; 0 = unlimited
CHUNK_SIZE=8388608                  # 8 MiB

# ── Redis (optional) ──
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Logging ──
LOG_LEVEL=info                      # debug | info | warn | error
LOG_FORMAT=json                     # json | console
